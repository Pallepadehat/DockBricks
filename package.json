{
  "name": "dockbricks",
  "private": true,
  "version": "0.1.1",
  "description": "Desktop app for managing local Docker/Podman databases",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pallepadehat/DockBricks.git"
  },
  "bugs": {
    "url": "https://github.com/pallepadehat/DockBricks/issues"
  },
  "homepage": "https://github.com/pallepadehat/DockBricks#readme",
  "keywords": [
    "tauri",
    "docker",
    "podman",
    "database",
    "desktop"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "test:rust": "cd src-tauri && cargo test",
    "check:rust": "cd src-tauri && cargo fmt --all --check && cargo clippy --all-targets && cargo check",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },

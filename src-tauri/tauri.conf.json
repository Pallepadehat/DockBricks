{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dockbricks",
  "version": "0.1.1",
  "identifier": "com.pallepadehat.dockbricks",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DockBricks",
        "width": 850,
        "height": 650,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFRDYyN0VCNjNGQ0UyNTQKUldSVTR2eGo2eWZXWG1FZ1FWZmh6VGVZV1NoWHdiWm5JWjJxNDgzUmRxOUhuWFA4N3EwZ1hzMzcK",
      "endpoints": [
        "https://github.com/pallepadehat/DockBricks/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
